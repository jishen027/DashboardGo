# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; never commit real secrets.

# ── Logto ─────────────────────────────────────────────────────────────────────
# Your self-hosted Logto instance URL, as seen from the public internet
# (routed via Nginx reverse proxy → VPN tunnel → internal Logto container).
LOGTO_ENDPOINT=https://auth.promptnotfound.com

# Application credentials — Logto Admin Console › Applications › <your app>
LOGTO_APP_ID=your_app_id_here
LOGTO_APP_SECRET=your_app_secret_here

# ── Next.js App ───────────────────────────────────────────────────────────────
# Your dashboard's canonical public URL — NO trailing slash.
# The SDK constructs the OIDC redirect_uri as:
#   NEXT_PUBLIC_APP_URL + /api/logto/sign-in-callback
# This value must be registered in Logto Admin Console (see below).
NEXT_PUBLIC_APP_URL=https://your-dashboard.example.com

# AES-256 encryption key for the iron-session cookie (min 32 chars).
# Generate: openssl rand -hex 32
LOGTO_COOKIE_SECRET=replace_with_64_hex_chars_from_openssl_rand
